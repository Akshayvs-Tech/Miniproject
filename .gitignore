# ─── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/

# ─── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Environment variables ─────────────────────────────────────────────────────
.env

# ─── ML model weights ──────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.pkl
ml_pipeline/src/

# ─── SlowFast / large asset directories ────────────────────────────────────────
# These directories can contain multi-hundred-MB model weights and raw footage.
# Use Git LFS (see GIT_LFS_GUIDE.md) if you need to version-control these assets.
slowfast-model/
sample-footage/

# ─── Large binary / generated asset file types ─────────────────────────────────
*.npy
*.mp4
*.dav
demo_output_*

# ─── Data / outputs ────────────────────────────────────────────────────────────
data/inputs/*
data/outputs/*
!data/inputs/.gitkeep
!data/outputs/.gitkeep

# ─── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
.next/
frontend/.next/

# ─── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ─── Logs ──────────────────────────────────────────────────────────────────────
*.log
