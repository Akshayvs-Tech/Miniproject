# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc

# Model weights and checkpoints (anywhere in ml_pipeline/)
*.pt
*.pth
*.onnx
*.pkl
*.npy
# Also ignore anything placed directly in the models/ folder
models/*

# Media / data files
*.mp4
*.avi
*.dav
*.mov
*.mkv
data/images/*
data/videos/*
outputs/*
demo_output_*

# Keep empty folders via .gitkeep
!data/images/.gitkeep
!data/videos/.gitkeep
!models/.gitkeep
!outputs/.gitkeep

# OS files
.DS_Store
Thumbs.db